### 9. Error Handling and Validation

**Ambiguous Prompt Patterns:**
- "validate configuration"
- "handle errors"
- "check settings"
- No specific validation mentioned

**Standard Validation Pattern:**

```javascript
// ALWAYS validate in onAppInstall
exports = {
  onAppInstallHandler: async function(args) {
    const iparams = args.iparams || {};
    
    // Validate required fields
    const validationErrors = [];
    
    if (!iparams.api_key || iparams.api_key.trim() === '') {
      validationErrors.push('API key is required');
    }
    
    if (!iparams.target_url || !isValidUrl(iparams.target_url)) {
      validationErrors.push('Valid target URL is required');
    }
    
    // Optional: Test API connection
    try {
      await testConnection(iparams);
      console.log('✅ Connection test successful');
    } catch (error) {
      validationErrors.push(`Connection test failed: ${error.message}`);
    }
    
    // Log validation results
    if (validationErrors.length > 0) {
      console.error('❌ Validation errors:', validationErrors);
      // Note: Can't prevent install, but log for debugging
    } else {
      console.log('✅ App installed and validated successfully');
    }
  }
};

function isValidUrl(url) {
  try {
    new URL(url);
    return true;
  } catch {
    return false;
  }
}

async function testConnection(iparams) {
  // Make a simple test API call
  const response = await $request.invokeTemplate('testConnection', {
    context: { api_key: iparams.api_key }
  });
  return response;
}
```

**Standard Error Handling in Event Handlers:**

```javascript
exports = {
  onTicketCreateHandler: async function(args) {
    try {
      // Main logic
      await processTicket(args);
      console.log('✅ Ticket processed successfully');
      
    } catch (error) {
      // Log error with context
      console.error('❌ Error processing ticket:', {
        ticketId: args.data?.ticket?.id,
        error: error.message,
        stack: error.stack
      });
      
      // Don't throw - event handlers should not fail silently
      // Platform will retry automatically on uncaught errors
    }
  }
};
```

**Decision Rule:**
```
ALWAYS implement:
  1. onAppInstall validation (check required iparams, test connection)
  2. try/catch in all event handlers
  3. Detailed error logging with context (ticket ID, error message)
  4. Graceful degradation (log error but don't crash)

NEVER:
  1. Let errors propagate uncaught
  2. Fail silently without logging
  3. Assume iparams are valid without checking
```

