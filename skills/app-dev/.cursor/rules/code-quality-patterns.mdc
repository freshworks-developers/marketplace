## Pattern 1: Function Complexity ≤ 5 (STRICT)

**Warning:** `Function 'X' has a complexity of Y. Maximum allowed is 7.`

**Target:** Keep complexity at 5 or below for maintainability.

### Technique 1: Lookup Objects (Replace if/else chains)

```javascript
// ❌ WRONG: Complexity 6+ (multiple if/else)
function getPriorityLabel(priority) {
  if (priority === 1) return 'Low';
  else if (priority === 2) return 'Medium';
  else if (priority === 3) return 'High';
  else if (priority === 4) return 'Urgent';
  else return 'Unknown';
}

// ✅ CORRECT: Complexity 1 (lookup)
const PRIORITY_LABELS = { 1: 'Low', 2: 'Medium', 3: 'High', 4: 'Urgent' };

function getPriorityLabel(priority) {
  return PRIORITY_LABELS[priority] ?? 'Unknown';
}
```

### Technique 2: Guard Clauses (Reduce nesting)

```javascript
// ❌ WRONG: Complexity 5+ (nested conditions)
function processTicket(ticket) {
  if (ticket) {
    if (ticket.status === 'open') {
      if (ticket.priority >= 3) {
        if (ticket.assignee) {
          return handleUrgent(ticket);
        }
      }
    }
  }
  return null;
}

// ✅ CORRECT: Complexity 4 (guard clauses)
function processTicket(ticket) {
  if (!ticket) return null;
  if (ticket.status !== 'open') return null;
  if (ticket.priority < 3) return null;
  if (!ticket.assignee) return null;
  return handleUrgent(ticket);
}
```

### Technique 3: Functional Patterns (Replace loops with conditions)

```javascript
// ❌ WRONG: Complexity 6+ (loop + conditions)
function getUrgentTicketIds(tickets) {
  const result = [];
  for (let i = 0; i < tickets.length; i++) {
    if (tickets[i].status === 'open') {
      if (tickets[i].priority >= 3) {
        result.push(tickets[i].id);
      }
    }
  }
  return result;
}

// ✅ CORRECT: Complexity 1 (functional chain)
function getUrgentTicketIds(tickets) {
  return tickets
    .filter(t => t.status === 'open' && t.priority >= 3)
    .map(t => t.id);
}
```

### Technique 4: Sets/Arrays for Multiple Comparisons

```javascript
// ❌ WRONG: Complexity 12 (multiple OR comparisons)
function matchesPriority(ticket, filter) {
  const p = (ticket.priority || ticket.urgency || 0).toString();
  const f = (filter || '').toLowerCase();
  if (f.includes('high') && (p === '2' || p === '3' || p === 'high' || p === 'urgent')) return true;
  if (f.includes('urgent') && (p === '3' || p === 'urgent')) return true;
  return false;
}

// ✅ CORRECT: Complexity 3 (use Set for membership check)
const HIGH_PRIORITIES = new Set(['2', '3', 'high', 'urgent']);
const URGENT_PRIORITIES = new Set(['3', 'urgent']);

function matchesPriority(ticket, filter) {
  const p = (ticket.priority || ticket.urgency || 0).toString();
  const f = (filter || '').toLowerCase();
  if (f.includes('high') && HIGH_PRIORITIES.has(p)) return true;
  if (f.includes('urgent') && URGENT_PRIORITIES.has(p)) return true;
  return false;
}
```

### Technique 5: Extract Helper Functions

```javascript
// ❌ WRONG: Complexity 8+ (everything in one function)
function buildNotificationPayload(ticket, user, config) {
  let payload = { type: 'ticket' };
  
  if (ticket.subject) {
    payload.title = ticket.subject;
  }
  if (ticket.description) {
    payload.body = ticket.description.substring(0, 200);
    if (ticket.description.length > 200) {
      payload.body += '...';
    }
  }
  if (config.includeUser && user) {
    payload.user = { name: user.name, email: user.email };
  }
  if (config.includePriority && ticket.priority) {
    if (ticket.priority === 4) payload.urgent = true;
    else if (ticket.priority === 3) payload.important = true;
  }
  
  return payload;
}

// ✅ CORRECT: Complexity 2 per function (extracted helpers)
function buildNotificationPayload(ticket, user, config) {
  return {
    type: 'ticket',
    ...buildTitleBody(ticket),
    ...buildUserInfo(user, config),
    ...buildPriorityFlags(ticket, config)
  };
}

function buildTitleBody(ticket) {
  const result = {};
  if (ticket.subject) result.title = ticket.subject;
  if (ticket.description) result.body = truncate(ticket.description, 200);
  return result;
}

function buildUserInfo(user, config) {
  if (!config.includeUser || !user) return {};
  return { user: { name: user.name, email: user.email } };
}

function buildPriorityFlags(ticket, config) {
  if (!config.includePriority || !ticket.priority) return {};
  return { urgent: ticket.priority === 4, important: ticket.priority === 3 };
}

function truncate(str, maxLen) {
  return str.length > maxLen ? str.substring(0, maxLen) + '...' : str;
}
```

### Technique 5: Data-Driven Configuration

```javascript
// ❌ WRONG: Complexity 10+ (large data mapping function)
function getFields(ticket) {
  const fields = [];
  if (ticket.id) fields.push({ name: 'ID', value: String(ticket.id), inline: true });
  if (ticket.subject) fields.push({ name: 'Subject', value: ticket.subject, inline: false });
  if (ticket.status === 2) fields.push({ name: 'Status', value: 'Open', inline: true });
  else if (ticket.status === 3) fields.push({ name: 'Status', value: 'Pending', inline: true });
  else if (ticket.status === 4) fields.push({ name: 'Status', value: 'Resolved', inline: true });
  else if (ticket.status === 5) fields.push({ name: 'Status', value: 'Closed', inline: true });
  if (ticket.priority === 1) fields.push({ name: 'Priority', value: 'Low', inline: true });
  else if (ticket.priority === 2) fields.push({ name: 'Priority', value: 'Medium', inline: true });
  else if (ticket.priority === 3) fields.push({ name: 'Priority', value: 'High', inline: true });
  else if (ticket.priority === 4) fields.push({ name: 'Priority', value: 'Urgent', inline: true });
  return fields;
}

// ✅ CORRECT: Complexity 3 (data-driven)
const STATUS_MAP = { 2: 'Open', 3: 'Pending', 4: 'Resolved', 5: 'Closed' };
const PRIORITY_MAP = { 1: 'Low', 2: 'Medium', 3: 'High', 4: 'Urgent' };

const FIELD_CONFIG = [
  { key: 'id', name: 'ID', inline: true, transform: String },
  { key: 'subject', name: 'Subject', inline: false },
  { key: 'status', name: 'Status', inline: true, map: STATUS_MAP },
  { key: 'priority', name: 'Priority', inline: true, map: PRIORITY_MAP }
];

function getFields(ticket) {
  return FIELD_CONFIG
    .filter(cfg => ticket[cfg.key] != null)
    .map(cfg => ({
      name: cfg.name,
      value: cfg.map ? cfg.map[ticket[cfg.key]] : (cfg.transform ? cfg.transform(ticket[cfg.key]) : ticket[cfg.key]),
      inline: cfg.inline
    }));
}
```

