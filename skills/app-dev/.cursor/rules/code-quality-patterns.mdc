## Pattern 3: Async Variable Scoping (No Race Conditions)

**Warning:** `'X' declared and assigned in different scopes. Possible asynchronous race condition.`

### Use IIFE Pattern (Preferred)

```javascript
// ❌ WRONG: Variables in different scopes
let client;
let currentData;

async function init() {
  client = await app.initialized();
}

async function loadData() {
  currentData = await client.data.get('ticket');
}

init();

// ✅ CORRECT: IIFE keeps everything in same scope
(async function() {
  const client = await app.initialized();
  
  client.events.on('app.activated', async () => {
    const ticketData = await client.data.get('ticket');
    render(ticketData);
  });
  
  function render(data) {
    document.getElementById('output').innerHTML = formatData(data);
  }
})();
```

### Pass Dependencies as Parameters

```javascript
// ❌ WRONG: Relies on global state
let client;

async function init() {
  client = await app.initialized();
  setupUI();
}

function setupUI() {
  document.getElementById('btn').addEventListener('fwClick', handleClick);
}

async function handleClick() {
  const data = await client.request.invoke('method', {});  // client may be undefined!
}

// ✅ CORRECT: Pass client as parameter
(async function() {
  const client = await app.initialized();
  setupUI(client);
})();

function setupUI(client) {
  document.getElementById('btn').addEventListener('fwClick', () => {
    handleClick(client).catch(console.error);
  });
}

async function handleClick(client) {
  const data = await client.request.invoke('method', {});
  renderResult(data);
}
```

### Use State Object Pattern

```javascript
// ✅ CORRECT: Centralized state object
(async function() {
  const app = {
    client: null,
    ticket: null,
    user: null
  };
  
  app.client = await window.app.initialized();
  
  app.client.events.on('app.activated', async () => {
    try {
      const [ticketData, userData] = await Promise.all([
        app.client.data.get('ticket'),
        app.client.data.get('loggedInUser')
      ]);
      app.ticket = ticketData.ticket;
      app.user = userData.loggedInUser;
      render(app);
    } catch (error) {
      console.error('Failed to load data:', error);
    }
  });
  
  function render(app) {
    document.getElementById('ticketInfo').innerHTML = 
      `Ticket #${app.ticket.id} - ${app.ticket.subject}`;
    document.getElementById('userInfo').innerHTML = 
      `Logged in as: ${app.user.name}`;
  }
})();
```

