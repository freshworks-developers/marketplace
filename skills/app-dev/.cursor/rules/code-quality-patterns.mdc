## Pattern 2: Promise Rejection Handling

**Warning:** `Expected rejection to be handled.`

### Frontend: Always wrap async calls

```javascript
// ❌ WRONG: No error handling
document.getElementById('btn').addEventListener('fwClick', async () => {
  const result = await client.request.invoke('fetchData', {});
  renderResult(result);
});

// ✅ CORRECT: try/catch wrapper
document.getElementById('btn').addEventListener('fwClick', async () => {
  try {
    const result = await client.request.invoke('fetchData', {});
    renderResult(result);
  } catch (error) {
    console.error('Failed to fetch data:', error);
    showErrorMessage('Unable to load data. Please try again.');
  }
});
```

### Frontend: Promise chains need .catch()

```javascript
// ❌ WRONG: No .catch()
client.data.get('ticket').then(data => {
  renderTicket(data.ticket);
});

// ✅ CORRECT: Add .catch()
client.data.get('ticket')
  .then(data => {
    renderTicket(data.ticket);
  })
  .catch(error => {
    console.error('Failed to get ticket:', error);
    showPlaceholder();
  });
```

### Backend: All SMI functions need try/catch

```javascript
// ❌ WRONG: No error handling
exports = {
  fetchExternalData: async function(args) {
    const response = await $request.invokeTemplate('externalApi', {
      context: { id: args.data.id }
    });
    return JSON.parse(response.response);
  }
};

// ✅ CORRECT: Proper error handling with informative return
exports = {
  fetchExternalData: async function(args) {
    try {
      const response = await $request.invokeTemplate('externalApi', {
        context: { id: args.data.id }
      });
      return { success: true, data: JSON.parse(response.response) };
    } catch (error) {
      console.error('External API call failed:', error);
      return { 
        success: false, 
        error: error.message || 'Unknown error',
        status: error.status || 500
      };
    }
  }
};
```

### Canonical Error-Safe Frontend Pattern

```javascript
(async function() {
  try {
    const client = await app.initialized();
    
    client.events.on('app.activated', () => {
      loadInitialData(client).catch(handleFatalError);
    });
    
    setupEventListeners(client);
  } catch (error) {
    handleFatalError(error);
  }
})();

async function loadInitialData(client) {
  const [ticketData, userData] = await Promise.all([
    client.data.get('ticket').catch(() => ({ ticket: null })),
    client.data.get('loggedInUser').catch(() => ({ loggedInUser: null }))
  ]);
  render(ticketData.ticket, userData.loggedInUser);
}

function setupEventListeners(client) {
  const btn = document.getElementById('actionBtn');
  if (btn) {
    btn.addEventListener('fwClick', () => handleAction(client).catch(showError));
  }
}

async function handleAction(client) {
  showLoading();
  try {
    const result = await client.request.invoke('performAction', {});
    if (result.success) {
      showSuccess(result.data);
    } else {
      showError(result.error);
    }
  } finally {
    hideLoading();
  }
}

function handleFatalError(error) {
  console.error('Fatal error:', error);
  document.body.innerHTML = '<fw-inline-message type="error">App failed to load</fw-inline-message>';
}

function showError(error) {
  const msg = typeof error === 'string' ? error : (error.message || 'An error occurred');
  console.error('Error:', error);
  document.getElementById('errorMsg').textContent = msg;
}
```

